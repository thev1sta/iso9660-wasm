{
	"name": "iso9660-wasm",
	"version": "0.1.0",
	"description": "Work with ISO images in browser, powered by WASM Go",
	"repository": "https://github.com/thev1sta/iso9660-wasm.git",
	"author": "thev1sta",
	"license": "BSD-2-Clause",
	"private": false,
	"type": "module",
	"types": "./dist/index.d.ts",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"browser": "./dist/index.js",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./iso9660.wasm": "./dist/iso9660.wasm",
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"packageManager": "yarn@1.22.22",
	"scripts": {
		"build:wasm": "make wasm",
		"build": "yarn build:wasm && tsdown",
		"pretest": "yarn build",
		"test": "node --test \"test/**/*.test.mjs\"",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3"
	}
}
